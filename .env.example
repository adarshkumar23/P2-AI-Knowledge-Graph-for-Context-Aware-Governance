# Core backend connection (agent-push / inbound-only — see PATENT.md).
# The satellite calls out to core; core never calls the satellite.
CORE_BASE_URL=http://localhost:8000

# Scoped keys issued once by core for patent_export:p2:read / patent_ingest:p2:write.
# These are NOT normal user credentials. Rotate via core's admin tooling; never commit real values.
CORE_EXPORT_API_KEY=dev-export-key
CORE_INGEST_API_KEY=dev-ingest-key

# Hybrid trigger: safety-net reconciliation poll interval (hours). Tunable config,
# NOT a claim element — see PATENT.md CHANGE LOG. Event-triggered traversal is the
# primary path; this poll only catches missed/failed events.
SAFETY_NET_POLL_HOURS=2

# Event listener (receives HMAC-signed change-event notifications from core's outbox).
EVENT_LISTENER_HOST=0.0.0.0
EVENT_LISTENER_PORT=8501
EVENT_LISTENER_SHARED_SECRET=change-me-shared-secret

# Webhook replay/freshness guard: reject a signed event notification whose
# timestamp is more than this many seconds old (or in the future), and reject
# exact replays of an already-seen (timestamp, signature) pair within this
# window. See event_listener.py's verify_signature().
EVENT_WEBHOOK_MAX_CLOCK_SKEW_SECONDS=300

# Optional defense-in-depth: comma-separated IP allowlist for the webhook
# endpoint. Empty (default) disables this check entirely -- HMAC verification
# alone still gates access. Only enable if core's real egress uses stable,
# known IPs (unverified from this satellite-only repo).
EVENT_LISTENER_IP_ALLOWLIST=

# Safety-net poll batch pacing: a large sweep is chunked into groups of at
# most this many derivations per push_derivations_batch() call, with this
# many seconds paced between chunks, so a large fleet's sweep never bursts
# past core's per-scoped-key ingest rate limit in one shot. MUST be tuned in
# lockstep with core's real rate limit (core-side-patch/rate_limiter.py)
# before go-live at large fleet sizes -- see PERFORMANCE.md and
# MERGE_CHECKLIST.md.
INGEST_BATCH_CHUNK_SIZE=50
INGEST_BATCH_PACE_SECONDS=30

# Traversal safety bound — configurable, referenced from settings.max_traversal_depth
# only (never hardcoded). NOT a claim element — see PATENT.md CHANGE LOG.
MAX_TRAVERSAL_DEPTH=6

# Embeddings for semantic node matching (pgvector on core side).
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Bump this when the traversal/derivation methodology changes; written to every
# audit log row and every governance_graph_traversal_results row.
METHODOLOGY_VERSION=p2-v1.0.0
